{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "types": [
      "node"
    ],
    "paths": {
      "@assets/*": [
        "./src/assets/*"
      ]
    }
  }
}