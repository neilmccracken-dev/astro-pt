---
import { Image } from 'astro:assets';
import logoImage from '../assets/images/mvmnt-skyblue-logo.png';
import MvmntLogo from '../assets/images/MVMNT-logo-hotizontal2-dark.svg';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="navbar w-full bg-deeper-teal shadow-md">
  <nav class="w-full flex justify-between items-center px-4 py-1">
    <div class="flex mt-8">
      <a href={`${import.meta.env.BASE_URL}`} class="flex items-center">
        <MvmntLogo class="w-62 h-20 lg:w-2xl md:h-24 fill-deeper-teal" />
      </a>
    </div>

    <div class="lg:flex items-center gap-6 hidden">
      <a
        href={`${import.meta.env.BASE_URL}about`}
        class="link link-hover font-montserrat text-white tracking-wider"
        >About</a
      >
      <a
        href={`${import.meta.env.BASE_URL}services`}
        class="link link-hover font-montserrat tracking-wider text-white"
        >Services</a
      >
      <a
        href={`${import.meta.env.BASE_URL}blog`}
        class="link link-hover font-montserrat tracking-wider text-white"
        >Blog</a
      >
      <a
        href={`${import.meta.env.BASE_URL}contact`}
        class="link link-hover font-montserrat tracking-wider text-white"
        >Contact</a
      >
      <a
        href={`${import.meta.env.BASE_URL}pricing`}
        class="link link-hover font-montserrat tracking-wider text-white"
        >Book</a
      >
      <a
        href={`${import.meta.env.BASE_URL}testimonials`}
        class="link link-hover font-montserrat tracking-wider text-white"
        >Testimonials</a
      >
    </div>
    <div class="drawer drawer-end ml-auto flex justify-end lg:hidden">
      <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />

      <div class="drawer-content">
        <label
          for="mobile-drawer"
          class="btn btn-square btn-sm bg-white border-0 p-0 w-12 h-12 drop-shadow-sm"
          aria-label="Open menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 stroke-deeper-teal drop-shadow-sm"
            viewBox="0 0 24 24"
            fill="none"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="3"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </label>
      </div>

      <div class="drawer-side z-50">
        <label for="mobile-drawer" class="drawer-overlay"></label>

        <ul class="menu bg-sky w-48 p-4 text-stone-600">
          <li><a href={`${import.meta.env.BASE_URL}`}>Home</a></li>
          <li><a href={`${import.meta.env.BASE_URL}about`}>About</a></li>
          <li><a href={`${import.meta.env.BASE_URL}services`}>Services</a></li>
          <li><a href={`${import.meta.env.BASE_URL}blog`}>Blog</a></li>
          <li>
            <a href={`${import.meta.env.BASE_URL}testimonials`}>Testimonials</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
