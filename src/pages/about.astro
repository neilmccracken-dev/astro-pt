---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import elieHeadshot from '../assets/images/headshot.jpg';
interface Props {
  index?: number;
}
const { index = 1 } = Astro.props;
const backgroundImg =
  'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?q=80&w=1920&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&sat=-100';

const optimizedBackground = await getImage({
  src: backgroundImg,
  format: 'webp',
  inferSize: true,
  widths: [1024, 1440, 1920, 2560],
});
---

<BaseLayout hasWave={true} title="About">
  <div class="grid grid-cols-6 w-full min-w-0">
    <!-- Top Row spanning the full width -->
    <div
      style={`background-image: url('${optimizedBackground.src}');`}
      class="col-span-full w-full bg-base-200 text-white rounded-lg bg-cover bg-center bg-no-repeat min-h-220"
    >
      <div
        class="w-full p-6 bg-black/80 backdrop-blur-md border border-white/10 text-center"
      >
        <h2 class="text-3xl font-bold mb-2 font-raleway tracking-wide">
          Making you strong and healthy is our mission!
        </h2>
      </div>
    </div>

    <div class="col-span-6 p-5 py-8">
      <div
        class="flex flex-col-reverse md:flex-row items-center justify-center gap-8"
      >
        <!-- Text -->
        <div class="bio flex-1 max-w-3xl" style={`--i: ${index};`}>
          <h2 class="mb-4 text-2xl font-bold font-raleway italic">
            Elie Sabins
            <span class="ml-2 text-lg font-medium">
              PT, DPT, OCS, CSCS, TPS
            </span>
          </h2>

          <p class="text-lg leading-loose">
            Elie grew up in Bellingham, WA, and went on to obtain her BS in
            Biology from the University of Washington in Seattle. During her
            years as a graduate student, she completed an internship with Howard
            Head before receiving her Doctorate from Belmont University in
            Nashville, TN. She takes a holistic approach to physical therapy and
            also enjoys bringing components of strength and conditioning into
            her treatment sessions. In her spare time, she enjoys running,
            hiking, skiing, and spending time with friends and family.
          </p>
        </div>

        <div class="bio flex justify-center md:w-1/3" data-attribute={index}>
          <Image
            src={elieHeadshot}
            alt="Elie Sabins"
            class="w-48 md:w-72 rounded-full border-2 border-deep-teal md:translate-y-8"
          />
        </div>
      </div>
    </div>

    <div class="col-span-6 bg-white py-16 md:py-24 md:my-20">
      <div class="relative bg-sky w-full">
        <div
          class="absolute top-0 left-0 w-full overflow-hidden leading-0 -translate-y-[100%]"
        >
          <svg
            preserveAspectRatio="none"
            class="relative block w-full h-24 md:h-52 fill-sky"
            xmlns="http://w3.org"
            viewBox="0 0 1440 320"
          >
            <path
              d="M0,192L60,170.7C120,149,240,107,360,101.3C480,96,600,128,720,165.3C840,203,960,245,1080,240C1200,235,1320,181,1380,154.7L1440,128L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"
            ></path>
          </svg>
        </div>

        <div
          class="relative z-10 h-full flex items-center justify-center px-4 pt-8 pb-20 md:px-8 md:py-16"
        >
          <div
            class="experience grid grid-cols-1 md:grid-cols-3 gap-4 w-full md:max-w-[90%] max-w-[80%] -translate-y-4"
          >
            <div
              class="relative overflow-hidden bg-base-100 card-bio md:min-h-56 shadow-xl rounded px-2"
            >
              <!-- Blob 1: Bottom-Left (Warm Peach) -->
              <div
                class="absolute -bottom-16 -left-16 w-44 h-44 bg-slate-300/80 rounded-full blur-3xl opacity-50 pointer-events-none"
              >
              </div>

              <!-- Blob 2: Top-Right (Soft Pink) -->
              <div
                class="absolute -top-16 -right-16 w-44 h-44 bg-stone-300 rounded-full blur-3xl opacity-50 pointer-events-none"
              >
              </div>

              <!-- Blob 3: Center-Left (Soft Lavender) <-- NEW THIRD COLOR -->
              <div
                class="absolute top-12 -left-20 w-40 h-40 bg-blue-100/80 rounded-full blur-3xl opacity-50 pointer-events-none"
              >
              </div>

              <!-- Content Wrapper (relative and z-10 ensures text stays on top of the blur) -->
              <div class="relative z-10 text-slate-900">
                <p class="text-center font-semibold font-raleway p-2">
                  Education
                </p>
                <ul class="list-disc text-sm list-inside space-y-1">
                  <li>Belmont University-Doctorate in Physical Therapy</li>
                  <li>University of Washington-Undergraduate</li>
                </ul>
              </div>
            </div>
            <div
              class="relative overflow-hidden bg-base-100 card-bio md:min-h-56 shadow-xl rounded px-2"
            >
              <!-- Blob 1: Bottom-Left (Warm Peach) -->
              <div
                class="absolute -bottom-16 -left-16 w-44 h-44 bg-gray-300/70 rounded-full blur-3xl opacity-50 pointer-events-none"
              >
              </div>

              <!-- Blob 2: Top-Right (Soft Pink) -->
              <div
                class="absolute -top-16 -right-16 w-44 h-44 bg-ivory rounded-full blur-3xl opacity-40 pointer-events-none"
              >
              </div>

              <!-- Blob 3: Center-Left (Soft Lavender) <-- NEW THIRD COLOR -->
              <div
                class="absolute top-12 -left-20 w-40 h-40 bg-sand/80 rounded-full blur-3xl opacity-30 pointer-events-none"
              >
              </div>

              <!-- Content Wrapper (relative and z-10 ensures text stays on top of the blur) -->
              <div class="relative z-10 text-slate-900">
                <p class="p-2 text-center w-full font-semibold font-raleway">
                  Professional Experience
                </p>
                <ul class="list-disc text-sm list-inside space-y-1">
                  <li>Belmont University-Doctorate in Physical Therapy</li>
                  <li>University of Washington-Undergraduate</li>
                  <li>Over 5 years of outpatient orthopedic experience</li>
                </ul>
              </div>
            </div>

            <div
              class="relative overflow-hidden bg-[#FFFFFF] bg-[radial-gradient(at_0%_0%,hsla(195,70%,93%,0.7)_0,transparent_50%),radial-gradient(at_100%_100%,hsla(210,15%,88%,0.6)_0,transparent_50%)] card-bio md:min-h-56 shadow-xl rounded px-2"
            >
              <!-- Blob 1: Bottom-Left (Warm Peach) -->

              <!-- Content Wrapper (relative and z-10 ensures text stays on top of the blur) -->
              <div class="relative z-10 text-slate-900">
                <p class="p-2 text-center w-full font-semibold font-raleway">
                  Professional Experience
                </p>
                <ul class="list-disc text-sm list-inside space-y-1">
                  <li>Belmont University-Doctorate in Physical Therapy</li>
                  <li>University of Washington-Undergraduate</li>
                  <li>Over 5 years of outpatient orthopedic experience</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <div
          class="absolute bottom-0 left-0 w-full overflow-hidden leading-0 translate-y-[99%] -scale-x-100 -scale-y-100 transform"
        >
          <svg
            preserveAspectRatio="none"
            class="relative block w-full h-24 md:h-52 fill-sky"
            xmlns="http://w3.org"
            viewBox="0 0 1440 320"
          >
            <path
              d="M0,192L60,170.7C120,149,240,107,360,101.3C480,96,600,128,720,165.3C840,203,960,245,1080,240C1200,235,1320,181,1380,154.7L1440,128L1440,320L1380,320C1320,320,1200,320,1080,320C960,320,840,320,720,320C600,320,480,320,360,320C240,320,120,320,60,320L0,320Z"
            ></path>
          </svg>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .bio {
    /* 1. Initial hidden state */
    opacity: 0;
    translate: -5rem 0;
    scale: 1.5;

    /* 2. Transition rules */
    transition-property: opacity, translate, scale;
    transition-duration: 1.5s;
    transition-timing-function: ease-in-out;

    /* Pull the index value from the dataset via CSS attr() */
    transition-delay: calc(200ms * var(--i));
    will-change: opacity, translate, scale;
  }
  @media (min-width: 768px) {
    .bio {
      translate: -30rem 0;
      scale: 1.5;
    }
  }

  /* 3. Final visible state triggered by JS */
  .bio.is-in-view {
    opacity: 1;
    translate: 0 0;
    scale: 1;
  }
  .experience {
    opacity: 0;
    transform: translateY(2.5rem);
    transition-property: opacity, transform;
    transition-duration: 1s; /* Pure fades usually feel snappier at 1s instead of 1.5s */
    transition-timing-function: ease-out;

    /* Keeps your staggered layout delay feature active */
    will-change: opacity;
  }

  /* 2. Final visible state triggered by the Observer */
  .experience.fade-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  let activeObserver: IntersectionObserver | null = null;

  function initScrollAnimations() {
    // 1. Define the elements and their corresponding active classes
    const configs = [
      { selector: '.bio', activeClass: 'is-in-view' },
      { selector: '.experience', activeClass: 'fade-in' }, // Your new element
    ];

    // 2. Gather all elements that actually exist on the current page
    const elementsToWatch: { element: Element; activeClass: string }[] = [];
    console.log(elementsToWatch);
    configs.forEach(({ selector, activeClass }) => {
      document.querySelectorAll(selector).forEach((el) => {
        elementsToWatch.push({ element: el, activeClass });
      });
    });

    if (elementsToWatch.length === 0) return;

    // 3. Create a single observer instance
    activeObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Retrieve the custom class stored on the element's dataset
            const targetClass = (entry.target as HTMLElement).dataset
              .animationClass;
            if (targetClass) {
              entry.target.classList.add(targetClass);
            }
            activeObserver?.unobserve(entry.target);
          }
        });
      },
      {
        rootMargin: '0px 0px -150px 0px',
        threshold: 0.05,
      },
    );

    // 4. Attach the class mapping to the DOM element and start observing
    elementsToWatch.forEach(({ element, activeClass }) => {
      (element as HTMLElement).dataset.animationClass = activeClass;
      activeObserver?.observe(element);
    });
  }

  // Astro Lifecycle Hooks (Keep these exactly as you had them)
  initScrollAnimations();
  document.addEventListener('astro:after-swap', initScrollAnimations);
  document.addEventListener('astro:before-swap', () => {
    if (activeObserver) {
      activeObserver.disconnect();
      activeObserver = null;
    }
  });
</script>
