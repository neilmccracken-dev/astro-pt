---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const testimonials = await getCollection('testimonials');
const cardThemes = [
  { bg: 'bg-bianco-caldo', text: 'text-stone-800', subtext: 'text-stone-500' }, // Card 1 (and 5, 9...)
  { bg: 'bg-stone-600', text: 'text-white', subtext: 'text-stone-400' }, // Card 0 (and 4, 8...)
  {
    bg: 'bg-lino-naturale',
    text: 'text-stone-800',
    subtext: 'text-stone-500',
  }, // Card 2 (and 6, 10...)
  {
    bg: 'bg-brand-sky-blue',
    text: 'text-white',
    subtext: 'text-gray-700',
  }, // Card 3 (and 7, 11...)
];
---

<BaseLayout title="testimonials" hasWave={true}>
