  <div class="w-full py-12 px-4 mb-36">
    <div
      class="mx-auto grid max-w-7xl grid-cols-1 gap-5 md:grid-cols-3 auto-rows-[minmax(150px,_280px)] grid-flow-row-dense"
    >
      {
        testimonials.map((item, index) => {
          const { name, relationship, review, headline } = item.data;

          // Determine the layout state based on a pattern of 5
          const isFeatured = index % 5 === 0;
          const isTall = index % 5 === 2;

          // Cycle through your 4 color schemes sequentially (0, 1, 2, 3, 0, 1, 2...)
          const theme = cardThemes[index % cardThemes.length];

          return (
            <div
              class:list={[
                'relative overflow-hidden rounded-lg p-5 shadow-xl font-bold flex flex-col justify-between break-words',
                // Inject sequential background and text values safely
                theme.bg,
                theme.text,
                isFeatured && 'md:col-span-2',
                isTall && 'md:row-span-2',
              ]}
            >
              {index == 0 && (
                <div class="absolute -top-4 right-4 w-32 h-40 z-0 opacity-20 pointer-events-none">
                  <svg
                    class="w-32 h-40"
                    preserveAspectRatio="none"
                    viewBox="-2.4 -2.4 28.80 28.80"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    transform="matrix(1, 0, 0, 1, 0, 0)rotate(0)"
                    stroke="#b7cdd6"
                    stroke-width="0.00024000000000000003"
                  >
                    <g id="SVGRepo_bgCarrier" stroke-width="0" />
                    <g
                      id="SVGRepo_tracerCarrier"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke="#CCCCCC"
                      stroke-width="0.048"
                    />
                    <g id="SVGRepo_iconCarrier">
                      <path
                        fill-rule="evenodd"
                        clip-rule="evenodd"
                        d="M9.62231 6.78278C10.0546 6.43909 10.1265 5.81001 9.78277 5.3777C9.43908 4.94539 8.81001 4.87354 8.37769 5.21724C4.73471 8.11342 4 11.8784 4 16C4 17.6569 5.34315 19 7 19C8.65685 19 10 17.6569 10 16C10 14.3432 8.65685 13 7 13C6.71233 13 6.43412 13.0405 6.17076 13.1161C6.5162 10.5872 7.45738 8.50391 9.62231 6.78278ZM20 16C20 17.6569 18.6569 19 17 19C15.3431 19 14 17.6569 14 16C14 11.8784 14.7347 8.11342 18.3777 5.21724C18.81 4.87354 19.4391 4.94539 19.7828 5.3777C20.1265 5.81001 20.0546 6.43909 19.6223 6.78278C17.4574 8.50391 16.5162 10.5872 16.1708 13.1161C16.4341 13.0405 16.7123 13 17 13C18.6569 13 20 14.3432 20 16Z"
                        fill="#000000"
                      />
                    </g>
                  </svg>
                </div>
              )}
              <div class="flex flex-col gap-y-4 relative z-10 ">
                <div>
                  <h3 class="text-xl font-raleway">{name}</h3>
                  <p class:list={['text-sm italic', theme.subtext]}>
                    {relationship || 'Patient'}
                  </p>
                </div>
                <div class="flex">
                  <p
                    class:list={[
                      !isTall && 'font-bold opacity-90 tracking-wide leading-7',
                      (isTall || isFeatured) &&
                        ' tracking-wide font-semibold text-lg leading-8  ',
                    ]}
                  >
                    {review}
                  </p>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</BaseLayout>

